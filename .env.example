# Frontend
VITE_API_BASE_URL=http://localhost:18000

# Backend
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=18000
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-local-env
JWT_COOKIE_NAME=game_agent_session

# GitHub OAuth
# Callback URL to configure in GitHub OAuth App:
# http://localhost:18000/api/auth/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:18000/api/auth/oauth/github/callback

# MySQL
MYSQL_HOST=192.168.150.101
MYSQL_PORT=13306
MYSQL_DATABASE=game_agent
MYSQL_USER=game_agent
MYSQL_PASSWORD=game_agent_password
DATABASE_URL=mysql+pymysql://game_agent:game_agent_password@192.168.150.101:13306/game_agent

# MinIO / S3 compatible storage
MINIO_ENDPOINT=192.168.150.101:19000
MINIO_PUBLIC_ENDPOINT=http://192.168.150.101:19000
MINIO_ACCESS_KEY=game_agent_minio
MINIO_SECRET_KEY=game_agent_minio_password
MINIO_BUCKET=game-agent
MINIO_SECURE=false

# Agent / LLM
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=300
LLM_MAX_RETRIES=2
LLM_INPUT_COST_PER_1M_TOKENS=0
LLM_OUTPUT_COST_PER_1M_TOKENS=0
AGENT_MAX_REPAIR_ATTEMPTS=2
